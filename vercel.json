{
  "version": 2,
  "rewrites": [
    {
      "source": "/admin",
      "destination": "/web/admin/dashboard.html"
    },
    {
      "source": "/admin/",
      "destination": "/web/admin/dashboard.html"
    },
    {
      "source": "/admin/(.*)",
      "destination": "/web/admin/$1"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/",
      "destination": "/web/landing/index.html"
    },
    {
      "source": "/((?!web|admin|api).*)",
      "destination": "/web/landing/$1"
    }
  ]
}
