{
  "version": 2,
  "builds": [
    {
      "src": "api/main.py",
      "use": "@vercel/python"
    },
    {
      "src": "web/**",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    {
      "source": "/logo.png",
      "destination": "/web/logo.png"
    },
    {
      "source": "/admin",
      "destination": "/web/admin/dashboard.html"
    },
    {
      "source": "/admin/login",
      "destination": "/web/admin/login.html"
    },
    {
      "source": "/admin/(.*)",
      "destination": "/web/admin/$1"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/main.py"
    },
    {
      "source": "/signup",
      "destination": "/web/signup/index.html"
    },
    {
      "source": "/checkout",
      "destination": "/web/checkout/index.html"
    },
    {
      "source": "/login",
      "destination": "/web/login/index.html"
    },
    {
      "source": "/dashboard",
      "destination": "/web/user/dashboard.html"
    },
    {
      "source": "/",
      "destination": "/web/landing/index.html"
    },
    {
      "source": "/((?!web|admin|api|checkout|signup).*)",
      "destination": "/web/landing/$1"
    }
  ]
}
